<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EFNco</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="efn-wrapper">
        <!-- Sidebar -->
        <aside class="efn-sidebar">
            <div class="sidebar-logo">
                <a class="logo-mark" asp-controller="Home" asp-action="Index">
                    <div class="logo-icon">EF</div>
                    <div class="logo-text">
                        <span class="logo-title">EFNco</span>
                        <span class="logo-sub">Facility Network Control</span>
                    </div>
                </a>
            </div>

            <nav class="sidebar-nav">
                <span class="nav-section-label">Main</span>
                <a asp-controller="Home" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    Dashboard
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <span class="nav-section-label">Administration</span>
                    <a asp-controller="Admin" asp-action="Users"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Manage Users
                    </a>
                    <a asp-controller="Admin" asp-action="Permits"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Permit") == true ? "active" : "")">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                        Manage Permits
                    </a>
                }

                <span class="nav-section-label">Permits</span>
                <a asp-controller="Permit" asp-action="MyPermits"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Permit" ? "active" : "")">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    My Permits
                </a>

                <span class="nav-section-label">Account</span>
                <a asp-controller="Account" asp-action="Profile"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    My Profile
                </a>

                <a asp-controller="Account" asp-action="ChangePassword"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ChangePassword" ? "active" : "")">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                    Change Password
                </a>

                <!-- Sign Out -->
                <span class="nav-section-label" style="margin-top:8px;"></span>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="
                        width:100%; display:flex; align-items:center; gap:12px;
                        padding:10px 12px; border-radius:8px; background:none; border:none;
                        color:var(--gray-400); font-family:'DM Sans',sans-serif;
                        font-size:14px; font-weight:500; cursor:pointer; text-align:left;
                        transition:all 0.2s;">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Sign Out
                    </button>
                </form>
            </nav>

            <!-- User card at bottom -->
            <div class="sidebar-footer">
                <div class="user-card">
                    <div class="user-avatar">
                        @(ViewBag.UserName?.ToString()?.Substring(0, 1)?.ToUpper() ?? "U")
                    </div>
                    <div class="user-info">
                        <div class="user-name">@ViewBag.UserName</div>
                        <div class="user-role">@ViewBag.Role</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main -->
        <div class="efn-main">
            <header class="efn-topbar">
                <span class="topbar-title">@ViewData["Title"]</span>
                <div class="topbar-actions">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success" style="margin:0;padding:8px 14px;">
                            @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger" style="margin:0;padding:8px 14px;">
                            @TempData["Error"]
                        </div>
                    }
                </div>
            </header>

            <main class="efn-content">
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
