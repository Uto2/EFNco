@model EFNco.Models.ParkingPermit
@{
    ViewData["Title"] = "Cancel Permit";
}

<div style="max-width:480px;">
    <div style="margin-bottom:20px;">
        <a asp-action="MyPermits" class="btn-efn btn-outline" style="padding:7px 14px;font-size:13px;">← Back to My Permits</a>
    </div>

    <div class="efn-card">
        <div style="text-align:center;padding:16px 0 24px;">
            <div style="width:64px;height:64px;border-radius:50%;background:rgba(245,158,11,0.1);border:2px solid rgba(245,158,11,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="var(--warning)" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
            </div>
            <h2 style="font-size:20px;margin-bottom:8px;">Cancel Permit Application?</h2>
            <p style="color:var(--gray-400);font-size:14px;line-height:1.6;">
                Are you sure you want to cancel your permit application for<br>
                <strong style="color:var(--white);">@Model.Vehicle!.PlateNumber — @Model.Vehicle.Make @Model.Vehicle.Model</strong>?<br>
                <span style="color:var(--warning);font-size:13px;">This will also remove your registered vehicle.</span>
            </p>
        </div>

        <div style="display:flex;gap:10px;justify-content:center;">
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-efn" style="background:var(--warning);color:var(--navy);font-weight:600;padding:10px 24px;">Yes, Cancel It</button>
            </form>
            <a asp-action="MyPermits" class="btn-efn btn-outline" style="padding:10px 24px;">Keep It</a>
        </div>
    </div>
</div>
