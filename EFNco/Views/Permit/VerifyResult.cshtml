@model object
@{
    Layout = null; // Standalone page — no login required, no sidebar
    ViewData["Title"] = "Permit Verification";

    var permit   = Model as EFNco.Models.ParkingPermit;
    var isInvalid = Model is string s && s == "invalid";
    var notFound  = Model is string s2 && s2 == "notfound";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EFNco — Permit Verification</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: #0b0f1a;
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            background: #131929;
            border: 1px solid #1e2d45;
            border-radius: 16px;
            padding: 32px;
            max-width: 420px;
            width: 100%;
            text-align: center;
        }

        .logo {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: #3b82f6;
            margin-bottom: 24px;
            letter-spacing: 2px;
        }

        .status-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .status-icon.valid   { background: rgba(16,185,129,0.15); border: 2px solid rgba(16,185,129,0.4); }
        .status-icon.invalid { background: rgba(239,68,68,0.15);  border: 2px solid rgba(239,68,68,0.4); }
        .status-icon.expired { background: rgba(245,158,11,0.15); border: 2px solid rgba(245,158,11,0.4); }

        .status-title {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 6px;
        }
        .status-title.valid   { color: #6ee7b7; }
        .status-title.invalid { color: #fca5a5; }
        .status-title.expired { color: #fcd34d; }

        .status-sub {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 28px;
        }

        .info-grid {
            background: #0b0f1a;
            border-radius: 12px;
            padding: 20px;
            text-align: left;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .info-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #475569;
            margin-bottom: 3px;
        }

        .info-value {
            font-size: 14px;
            color: #e2e8f0;
            font-weight: 500;
        }

        .plate {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
        }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-approved { background: rgba(16,185,129,0.1); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); }
        .badge-expired  { background: rgba(245,158,11,0.1); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
        .badge-revoked  { background: rgba(239,68,68,0.1);  color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }

        .divider {
            border: none;
            border-top: 1px solid #1e2d45;
            margin: 20px 0;
        }

        .footer {
            font-size: 12px;
            color: #334155;
            margin-top: 8px;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">EFNco</div>

        @if (isInvalid || notFound)
        {
            <div class="status-icon invalid">
                <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#f87171" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </div>
            <div class="status-title invalid">Invalid QR Code</div>
            <div class="status-sub">This QR code is not recognized or has been tampered with.</div>
        }
        else if (permit != null)
        {
            var isExpired = permit.ValidUntil.HasValue && permit.ValidUntil.Value < DateTime.UtcNow;
            var isRevoked = permit.Status == EFNco.Models.PermitStatus.Revoked;
            var isValid   = permit.Status == EFNco.Models.PermitStatus.Approved && !isExpired && !isRevoked;

            @if (isValid)
            {
                <div class="status-icon valid">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#6ee7b7" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                <div class="status-title valid">Valid Permit</div>
                <div class="status-sub">This vehicle is authorized to enter the campus.</div>
            }
            else if (isExpired)
            {
                <div class="status-icon expired">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#fcd34d" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="status-title expired">Permit Expired</div>
                <div class="status-sub">This permit has expired and is no longer valid.</div>
            }
            else
            {
                <div class="status-icon invalid">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#f87171" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                    </svg>
                </div>
                <div class="status-title invalid">Permit Revoked</div>
                <div class="status-sub">This permit has been revoked and is no longer valid.</div>
            }

            <div class="info-grid">
                <div style="grid-column: 1 / -1;">
                    <div class="info-label">Plate Number</div>
                    <div class="plate">@permit.Vehicle!.PlateNumber</div>
                </div>
                <div>
                    <div class="info-label">Vehicle</div>
                    <div class="info-value">@permit.Vehicle.Make @permit.Vehicle.Model</div>
                </div>
                <div>
                    <div class="info-label">Type</div>
                    <div class="info-value">@permit.Vehicle.VehicleType</div>
                </div>
                <div>
                    <div class="info-label">Permit Type</div>
                    <div class="info-value">@permit.PermitType</div>
                </div>
                <div>
                    <div class="info-label">Status</div>
                    @if (isExpired)
                    {
                        <span class="badge badge-expired">Expired</span>
                    }
                    else if (isRevoked)
                    {
                        <span class="badge badge-revoked">Revoked</span>
                    }
                    else
                    {
                        <span class="badge badge-approved">Approved</span>
                    }
                </div>
                @if (permit.ValidFrom.HasValue)
                {
                    <div>
                        <div class="info-label">Valid From</div>
                        <div class="info-value">@permit.ValidFrom.Value.ToString("MMM dd, yyyy")</div>
                    </div>
                }
                @if (permit.ValidUntil.HasValue)
                {
                    <div>
                        <div class="info-label">Valid Until</div>
                        <div class="info-value">@permit.ValidUntil.Value.ToString("MMM dd, yyyy")</div>
                    </div>
                }
                <div>
                    <div class="info-label">Permit #</div>
                    <div class="info-value">#@permit.Id</div>
                </div>
                <div>
                    <div class="info-label">Holder</div>
                    <div class="info-value">@permit.Applicant?.FullName</div>
                </div>
            </div>

            <hr class="divider" />
            <div class="footer">
                Verified via EFNco Parking Permit System &bull; @DateTime.Now.ToString("MMM dd, yyyy h:mm tt")
            </div>
        }
    </div>
</body>
</html>
