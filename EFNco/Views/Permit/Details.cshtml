@model EFNco.Models.ParkingPermit
@{
    ViewData["Title"] = "Permit Details";
    var statusColor = Model.Status switch {
        EFNco.Models.PermitStatus.Approved => "rgba(16,185,129,0.1);color:#6ee7b7;border:1px solid rgba(16,185,129,0.25)",
        EFNco.Models.PermitStatus.Pending  => "rgba(245,158,11,0.1);color:#fcd34d;border:1px solid rgba(245,158,11,0.25)",
        EFNco.Models.PermitStatus.Rejected => "rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.25)",
        EFNco.Models.PermitStatus.Revoked  => "rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.25)",
        EFNco.Models.PermitStatus.Expired  => "rgba(100,116,139,0.1);color:#94a3b8;border:1px solid rgba(100,116,139,0.25)",
        _ => "rgba(100,116,139,0.1);color:#94a3b8;border:1px solid rgba(100,116,139,0.25)"
    };
}

<div style="max-width:600px;">
    <div style="margin-bottom:20px;">
        <a asp-action="MyPermits" class="btn-efn btn-outline" style="padding:7px 14px;font-size:13px;">← Back to My Permits</a>
    </div>

    @* ── Permit Info ── *@
    <div class="efn-card" style="margin-bottom:16px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border);">
            <div>
                <h2 style="font-size:20px;font-family:'Syne',sans-serif;">Permit #@Model.Id</h2>
                <p style="font-size:13px;color:var(--gray-400);margin-top:4px;">Applied @Model.AppliedAt.ToString("MMMM dd, yyyy")</p>
            </div>
            <span class="badge" style="background:@statusColor;font-size:13px;padding:5px 14px;">@Model.Status</span>
        </div>

        <h3 style="font-size:13px;text-transform:uppercase;letter-spacing:1px;color:var(--gray-500);margin-bottom:12px;">Vehicle</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
            <div>
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Plate Number</div>
                <div style="font-size:15px;font-weight:600;color:var(--white);font-family:'Syne',sans-serif;">@Model.Vehicle!.PlateNumber</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Type</div>
                <div style="font-size:14px;color:var(--gray-300);">@Model.Vehicle.VehicleType</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Make & Model</div>
                <div style="font-size:14px;color:var(--gray-300);">@Model.Vehicle.Make @Model.Vehicle.Model</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Year / Color</div>
                <div style="font-size:14px;color:var(--gray-300);">@(Model.Vehicle.Year ?? "—") / @(Model.Vehicle.Color ?? "—")</div>
            </div>
        </div>

        <h3 style="font-size:13px;text-transform:uppercase;letter-spacing:1px;color:var(--gray-500);margin-bottom:12px;">Permit</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
            <div>
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Permit Type</div>
                <div style="font-size:14px;color:var(--gray-300);">@Model.PermitType</div>
            </div>
            <div>
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Status</div>
                <span class="badge" style="background:@statusColor;">@Model.Status</span>
            </div>
            @if (Model.ValidFrom.HasValue)
            {
                <div>
                    <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Valid From</div>
                    <div style="font-size:14px;color:var(--gray-300);">@Model.ValidFrom.Value.ToString("MMMM dd, yyyy")</div>
                </div>
            }
            @if (Model.ValidUntil.HasValue)
            {
                <div>
                    <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;">Valid Until</div>
                    <div style="font-size:14px;color:var(--gray-300);">@Model.ValidUntil.Value.ToString("MMMM dd, yyyy")</div>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Purpose))
        {
            <div style="margin-bottom:16px;">
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;">Your Notes</div>
                <div style="font-size:14px;color:var(--gray-300);background:var(--navy);padding:12px;border-radius:8px;">@Model.Purpose</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Remarks))
        {
            <div style="margin-bottom:16px;">
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;">Admin Remarks</div>
                <div style="font-size:14px;color:var(--gray-300);background:var(--navy);padding:12px;border-radius:8px;">@Model.Remarks</div>
            </div>
        }

        @if (Model.ReviewedBy != null)
        {
            <div style="font-size:12px;color:var(--gray-500);padding-top:12px;border-top:1px solid var(--border);margin-bottom:16px;">
                Reviewed by <strong style="color:var(--gray-400);">@Model.ReviewedBy.FullName</strong>
                on @Model.ReviewedAt?.ToString("MMMM dd, yyyy")
            </div>
        }

        @* ── Submitted Documents ── *@
        @if (Model.LicensePhotoData != null || Model.RegistrationFileData != null)
        {
            <div style="margin-top:4px;padding-top:16px;border-top:1px solid var(--border);">
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:14px;">Submitted Documents</div>
                <div style="display:flex;flex-direction:column;gap:14px;">

                    @if (Model.LicensePhotoData != null)
                    {
                        <div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;">
                            <div style="padding:10px 16px;background:var(--navy-light);display:flex;justify-content:space-between;align-items:center;">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--blue-glow)" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;color:var(--white);">Driver's License</div>
                                        <div style="font-size:11px;color:var(--gray-400);">@(Model.LicensePhotoFileName ?? "license-photo")</div>
                                    </div>
                                </div>
                                <a href="/Permit/ViewFile/@Model.Id?type=license" target="_blank"
                                   class="btn-efn btn-outline" style="padding:5px 12px;font-size:12px;">Open</a>
                            </div>
                            <div style="background:var(--navy);padding:12px;text-align:center;">
                                <img src="/Permit/ViewFile/@Model.Id?type=license"
                                     alt="License Photo"
                                     style="max-width:100%;max-height:260px;object-fit:contain;border-radius:6px;"
                                     onerror="showPreviewFallback(this)" />
                            </div>
                        </div>
                    }

                    @if (Model.RegistrationFileData != null)
                    {
                        var regExt = System.IO.Path.GetExtension(Model.RegistrationFileName ?? "").ToLowerInvariant();
                        <div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;">
                            <div style="padding:10px 16px;background:var(--navy-light);display:flex;justify-content:space-between;align-items:center;">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--blue-glow)" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                    </svg>
                                    <div>
                                        <div style="font-size:13px;font-weight:500;color:var(--white);">Vehicle Registration (OR/CR)</div>
                                        <div style="font-size:11px;color:var(--gray-400);">@(Model.RegistrationFileName ?? "registration")</div>
                                    </div>
                                </div>
                                <a href="/Permit/ViewFile/@Model.Id?type=registration" target="_blank"
                                   class="btn-efn btn-outline" style="padding:5px 12px;font-size:12px;">Open</a>
                            </div>
                            <div style="background:var(--navy);padding:12px;text-align:center;">
                                @if (regExt == ".pdf")
                                {
                                    <p style="font-size:13px;color:var(--gray-400);margin:8px 0;">PDF file — click <strong>Open</strong> to view in a new tab.</p>
                                }
                                else
                                {
                                    <img src="/Permit/ViewFile/@Model.Id?type=registration"
                                         alt="Registration"
                                         style="max-width:100%;max-height:260px;object-fit:contain;border-radius:6px;"
                                         onerror="showPreviewFallback(this)" />
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* ── QR / Digital Permit (Approved only) ── *@
    @if (Model.Status == EFNco.Models.PermitStatus.Approved && Model.QRCodeData != null)
    {
        <div class="efn-card" style="border-color:rgba(16,185,129,0.25);">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--success);">✅ Digital Permit</h3>
                <p style="font-size:13px;color:var(--gray-400);margin-top:4px;">
                    Your permit has been approved. Use the QR code below for gate entry.
                </p>
            </div>

            <div style="display:flex;gap:16px;align-items:center;flex-wrap:wrap;">
                <div style="background:white;border-radius:12px;padding:12px;flex-shrink:0;">
                    <img src="@Url.Action("QRImage", "Permit", new { id = Model.Id })"
                         alt="QR Code"
                         style="width:120px;height:120px;display:block;" />
                </div>
                <div style="display:flex;flex-direction:column;gap:10px;flex:1;min-width:180px;">
                    <a asp-action="QRView" asp-route-id="@Model.Id" class="btn-efn btn-primary">
                        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8H3m2 4H1m18 0h.01M5 20H3m2-4H1"/>
                        </svg>
                        View Full QR
                    </a>
                    <a href="@Url.Action("QRImage", "Permit", new { id = Model.Id })"
                       download="EFNco-Permit-@(Model.Id)-QR.png"
                       class="btn-efn btn-outline">
                        ⬇ Download QR
                    </a>
                    <a asp-action="PrintPermit" asp-route-id="@Model.Id" target="_blank" class="btn-efn btn-outline">
                        🖨 Print Permit
                    </a>
                </div>
            </div>

            @if (Model.IsExpired)
            {
                <div class="alert alert-danger" style="margin-top:16px;margin-bottom:0;">
                    ⚠ This permit has expired. Please apply for a renewal.
                </div>
            }
        </div>
    }
</div>

<script>
    function showPreviewFallback(img) {
        img.parentElement.innerHTML = '<p style="font-size:13px;color:#64748b;margin:8px 0;">Unable to preview \u2014 click Open to view.</p>';
    }
</script>
