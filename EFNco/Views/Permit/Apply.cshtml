@model EFNco.Models.ApplyPermitViewModel
@{
    ViewData["Title"] = "Apply for Permit";
}

<div style="max-width:640px;">
    <div style="margin-bottom:24px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Apply for Parking Permit</h2>
        <p style="color:var(--gray-400);font-size:14px;margin-top:4px;">Fill in your vehicle details and permit type. Your application will be reviewed by an administrator.</p>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger" style="margin-bottom:20px;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
            </svg>
            <div>
                <strong>Please fix the following errors:</strong>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>• @error.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <form method="post" action="/Permit/Apply">
        @Html.AntiForgeryToken()

        <div class="efn-card" style="margin-bottom:20px;">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--white);">🚗 Vehicle Information</h3>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Plate Number <span style="color:var(--danger)">*</span></label>
                    <input type="text" name="PlateNumber" value="@Model.PlateNumber"
                           class="form-control" placeholder="e.g. ABC 1234" style="text-transform:uppercase;" />
                    <span asp-validation-for="PlateNumber" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Vehicle Type <span style="color:var(--danger)">*</span></label>
                    <select name="VehicleType" class="form-control">
                        <option value="">— Select type —</option>
                        @if (Model.VehicleType == EFNco.Models.VehicleType.Car)
                        {
                            <option value="0" selected="selected">Car</option>
                            <option value="1">Motorcycle</option>
                        }
                        else if (Model.VehicleType == EFNco.Models.VehicleType.Motorcycle)
                        {
                            <option value="0">Car</option>
                            <option value="1" selected="selected">Motorcycle</option>
                        }
                        else
                        {
                            <option value="0">Car</option>
                            <option value="1">Motorcycle</option>
                        }
                    </select>
                    <span asp-validation-for="VehicleType" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Make / Brand <span style="color:var(--danger)">*</span></label>
                    <input type="text" name="Make" value="@Model.Make"
                           class="form-control" placeholder="e.g. Toyota" />
                    <span asp-validation-for="Make" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Model <span style="color:var(--danger)">*</span></label>
                    <input type="text" name="Model" value="@Model.Model"
                           class="form-control" placeholder="e.g. Vios" />
                    <span asp-validation-for="Model" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Year <span style="color:var(--gray-500)">(Optional)</span></label>
                    <input type="text" name="Year" value="@Model.Year"
                           class="form-control" placeholder="e.g. 2022" maxlength="4" />
                </div>
                <div class="form-group">
                    <label class="form-label">Color <span style="color:var(--gray-500)">(Optional)</span></label>
                    <input type="text" name="Color" value="@Model.Color"
                           class="form-control" placeholder="e.g. White" />
                </div>
            </div>
        </div>

        <div class="efn-card" style="margin-bottom:20px;">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--white);">📄 Permit Information</h3>
            </div>

            <div class="form-group">
                <label class="form-label">Permit Type <span style="color:var(--danger)">*</span></label>
                <select name="PermitType" class="form-control">
                    <option value="">— Select permit type —</option>
                    @if (Model.PermitType == EFNco.Models.PermitType.Faculty)
                    {
                        <option value="0">Student</option>
                        <option value="1" selected="selected">Faculty</option>
                        <option value="2">Staff</option>
                    }
                    else if (Model.PermitType == EFNco.Models.PermitType.Staff)
                    {
                        <option value="0">Student</option>
                        <option value="1">Faculty</option>
                        <option value="2" selected="selected">Staff</option>
                    }
                    else
                    {
                        <option value="0">Student</option>
                        <option value="1">Faculty</option>
                        <option value="2">Staff</option>
                    }
                </select>
                <span asp-validation-for="PermitType" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Purpose / Notes <span style="color:var(--gray-500)">(Optional)</span></label>
                <textarea name="Purpose" class="form-control" rows="3"
                          placeholder="Any additional information for the administrator...">@Model.Purpose</textarea>
            </div>
        </div>

        <div class="alert alert-warning" style="margin-bottom:20px;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>You can only have <strong>one active permit</strong> at a time. Your application will be reviewed by an administrator before approval.</span>
        </div>

        <div style="display:flex;gap:12px;">
            <button type="submit" class="btn-efn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
                Submit Application
            </button>
            <a asp-action="MyPermits" class="btn-efn btn-outline">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}