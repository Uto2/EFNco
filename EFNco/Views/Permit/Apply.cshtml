@model EFNco.Models.ApplyPermitViewModel
@{
    ViewData["Title"] = "Apply for Permit";
}

<div style="max-width:640px;">
    <div class="animated-banner" style="margin-bottom:24px; padding:24px 28px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;color:var(--white);margin-bottom:4px;">Apply for Parking Permit</h2>
        <p style="color:var(--gray-300);font-size:14px;">Fill in your details below. Your application will be reviewed by an administrator.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:20px;"></div>

    <form method="post" asp-action="Apply" asp-controller="Permit" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        @* ── Step 1: Permit Type (pick this first so user knows what they're applying Testttt for) ── *@
        <div class="efn-card card-animated" style="margin-bottom:20px; animation-delay: 0.1s;">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--white);">📄 Permit Type</h3>
            </div>
            <div class="form-group">
                <label asp-for="PermitType" class="form-label">Permit Type <span style="color:var(--danger)">*</span></label>
                <select asp-for="PermitType" class="form-control">
                    <option value="">— Select permit type —</option>
                    <option value="Student">Student</option>
                    <option value="Faculty">Faculty</option>
                    <option value="Staff">Staff</option>
                </select>
                <span asp-validation-for="PermitType" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Purpose" class="form-label">Purpose / Notes <span style="color:var(--gray-500)">(Optional)</span></label>
                <textarea asp-for="Purpose" class="form-control" rows="2"
                          placeholder="Any additional information for the administrator..."></textarea>
            </div>
        </div>

        @* ── Step 2: Vehicle Info ── *@
        <div class="efn-card card-animated" style="margin-bottom:20px; animation-delay: 0.2s;">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--white);">🚗 Vehicle Information</h3>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="PlateNumber" class="form-label">Plate Number <span style="color:var(--danger)">*</span></label>
                    <input asp-for="PlateNumber" class="form-control" placeholder="e.g. ABC 1234" style="text-transform:uppercase;" />
                    <span asp-validation-for="PlateNumber" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="VehicleType" class="form-label">Vehicle Type <span style="color:var(--danger)">*</span></label>
                    <select asp-for="VehicleType" class="form-control">
                        <option value="">— Select type —</option>
                        <option value="Car">Car</option>
                        <option value="Motorcycle">Motorcycle</option>
                    </select>
                    <span asp-validation-for="VehicleType" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Make" class="form-label">Make / Brand <span style="color:var(--danger)">*</span></label>
                    <input asp-for="Make" class="form-control" placeholder="e.g. Toyota" />
                    <span asp-validation-for="Make" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="VehicleModel" class="form-label">Model <span style="color:var(--danger)">*</span></label>
                    <input asp-for="VehicleModel" class="form-control" placeholder="e.g. Vios" />
                    <span asp-validation-for="VehicleModel" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Year" class="form-label">Year <span style="color:var(--gray-500)">(Optional)</span></label>
                    <input asp-for="Year" class="form-control" placeholder="e.g. 2022" maxlength="4" />
                </div>
                <div class="form-group">
                    <label asp-for="Color" class="form-label">Color <span style="color:var(--gray-500)">(Optional)</span></label>
                    <input asp-for="Color" class="form-control" placeholder="e.g. White" />
                </div>
            </div>
        </div>

        @* ── Step 3: Documents ── *@
        <div class="efn-card card-animated" style="margin-bottom:20px; animation-delay: 0.3s;">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--white);">📎 Supporting Documents</h3>
            </div>
            <p style="font-size:13px;color:var(--gray-400);margin-bottom:20px;">
                Upload clear photos or scans. JPG/PNG for license &bull; JPG/PNG/PDF for registration. Max 5 MB each.
            </p>

            @* License Photo *@
            <div class="form-group" style="margin-bottom:24px;">
                <label class="form-label">
                    🪪 Driver's License Photo
                    <span style="color:var(--gray-500);font-weight:400;">(Optional)</span>
                </label>
                <div id="licenseDropzone" onclick="document.getElementById('licenseInput').click()"
                     style="border:2px dashed var(--border);border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:border-color 0.2s;">
                    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="var(--gray-500)" stroke-width="1.5" style="margin-bottom:8px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <p id="licenseLabel" style="font-size:13px;color:var(--gray-400);margin:0;">Click to upload license photo</p>
                    <p style="font-size:11px;color:var(--gray-500);margin:4px 0 0;">JPG, PNG &bull; Max 5 MB</p>
                </div>
                <input type="file" id="licenseInput" name="LicensePhoto" accept=".jpg,.jpeg,.png" style="display:none;"
                       onchange="handleFile(this,'licenseDropzone','licenseLabel','licensePreview','licensePreviewImg','licensePreviewName','Click to upload license photo',true)" />
                <span asp-validation-for="LicensePhoto" class="field-validation-error"></span>
                <div id="licensePreview" style="display:none;margin-top:10px;border-radius:8px;overflow:hidden;border:1px solid var(--border);">
                    <img id="licensePreviewImg" src="" alt="License preview" style="width:100%;max-height:200px;object-fit:cover;display:block;" />
                    <div style="padding:8px 14px;background:var(--navy-light);display:flex;justify-content:space-between;align-items:center;">
                        <span id="licensePreviewName" style="font-size:12px;color:var(--gray-300);"></span>
                        <button type="button" onclick="clearFile('licenseInput','licenseDropzone','licenseLabel','licensePreview','Click to upload license photo')"
                                style="background:none;border:none;color:var(--danger);font-size:12px;cursor:pointer;">✕ Remove</button>
                    </div>
                </div>
            </div>

            @* Registration File *@
            <div class="form-group">
                <label class="form-label">
                    📋 Vehicle Registration (OR/CR)
                    <span style="color:var(--gray-500);font-weight:400;">(Optional)</span>
                </label>
                <div id="regDropzone" onclick="document.getElementById('regInput').click()"
                     style="border:2px dashed var(--border);border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:border-color 0.2s;">
                    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="var(--gray-500)" stroke-width="1.5" style="margin-bottom:8px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <p id="regLabel" style="font-size:13px;color:var(--gray-400);margin:0;">Click to upload OR/CR</p>
                    <p style="font-size:11px;color:var(--gray-500);margin:4px 0 0;">JPG, PNG, PDF &bull; Max 5 MB</p>
                </div>
                <input type="file" id="regInput" name="RegistrationFile" accept=".jpg,.jpeg,.png,.pdf" style="display:none;"
                       onchange="handleFile(this,'regDropzone','regLabel','regPreview','regPreviewImg','regPreviewName','Click to upload OR/CR',false)" />
                <span asp-validation-for="RegistrationFile" class="field-validation-error"></span>
                <div id="regPreview" style="display:none;margin-top:10px;border-radius:8px;border:1px solid var(--border);background:var(--navy-light);padding:12px 16px;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--blue-glow)" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span id="regPreviewName" style="font-size:13px;color:var(--gray-300);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
                        <button type="button" onclick="clearFile('regInput','regDropzone','regLabel','regPreview','Click to upload OR/CR')"
                                style="background:none;border:none;color:var(--danger);font-size:12px;cursor:pointer;flex-shrink:0;">✕ Remove</button>
                    </div>
                </div>
            </div>
        </div>

        @* ── Notice ── *@
        <div class="alert alert-warning" style="margin-bottom:20px;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>You can only have <strong>one active permit</strong> at a time. Your application will be reviewed by an administrator before approval.</span>
        </div>

        <div style="display:flex;gap:12px;">
            <button type="submit" class="btn-efn btn-primary">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                Submit Application
            </button>
            <a asp-action="MyPermits" class="btn-efn btn-outline">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function handleFile(input, dropId, labelId, previewId, imgId, nameId, defaultLabel, isImage) {
            const file = input.files[0];
            if (!file) return;
            document.getElementById(dropId).style.borderColor  = 'var(--blue)';
            document.getElementById(labelId).textContent        = file.name;
            document.getElementById(nameId).textContent         = file.name;
            document.getElementById(previewId).style.display    = 'block';
            if (isImage && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = e => { document.getElementById(imgId).src = e.target.result; };
                reader.readAsDataURL(file);
            }
        }
        function clearFile(inputId, dropId, labelId, previewId, defaultLabel) {
            document.getElementById(inputId).value               = '';
            document.getElementById(previewId).style.display     = 'none';
            document.getElementById(labelId).textContent          = defaultLabel;
            document.getElementById(dropId).style.borderColor    = 'var(--border)';
        }
    </script>
}
