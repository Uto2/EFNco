@model List<EFNco.Models.ParkingDurationSetting>
@{
    ViewData["Title"] = "Parking Duration Limits";
}

<div style="max-width:600px;">
    <div style="margin-bottom:24px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Parking Duration Limits</h2>
        <p style="color:var(--gray-400);font-size:14px;margin-top:4px;">
            Configure maximum parking durations per permit type. An overtime alert email is sent when exceeded.
        </p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" style="margin-bottom:20px;">✅ @TempData["Success"]</div>
    }

    <form asp-action="DurationLimits" asp-controller="AdminSettings" method="post">
        @Html.AntiForgeryToken()

        <div style="display:flex;flex-direction:column;gap:16px;">
            @for (int i = 0; i < Model.Count; i++)
            {
                var setting = Model[i];
                var icon = setting.PermitType switch {
                    EFNco.Models.PermitType.Student => "🎓",
                    EFNco.Models.PermitType.Faculty => "👨‍🏫",
                    EFNco.Models.PermitType.Staff   => "👔",
                    _ => "🪪"
                };

                <input type="hidden" name="models[@i].Id"         value="@setting.Id" />
                <input type="hidden" name="models[@i].PermitType" value="@((int)setting.PermitType)" />

                <div class="efn-card">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border);">
                        <span style="font-size:20px;">@icon</span>
                        <h3 style="font-size:16px;font-family:'Syne',sans-serif;">@setting.PermitType Permit</h3>
                        @if (setting.UpdatedAt != default)
                        {
                            <span style="font-size:11px;color:var(--gray-500);margin-left:auto;">
                                Last updated @setting.UpdatedAt.ToString("MMM dd, yyyy")
                            </span>
                        }
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Max Parking Hours</label>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <input type="number"
                                       name="models[@i].MaxHours"
                                       value="@setting.MaxHours"
                                       class="form-control"
                                       min="0.5" max="24" step="0.5"
                                       style="width:100px;" />
                                <span style="font-size:13px;color:var(--gray-400);">hours</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Grace Period</label>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <input type="number"
                                       name="models[@i].GraceMinutes"
                                       value="@setting.GraceMinutes"
                                       class="form-control"
                                       min="0" max="60" step="5"
                                       style="width:100px;" />
                                <span style="font-size:13px;color:var(--gray-400);">minutes</span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group" style="margin-top:4px;">
                        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                            <input type="checkbox"
                                   name="models[@i].AutoViolation"
                                   value="true"
                                   @(setting.AutoViolation ? "checked" : "")
                                   style="width:16px;height:16px;" />
                            @* Hidden false value so unchecked sends false *@
                            <input type="hidden" name="models[@i].AutoViolation" value="false" />
                            <div>
                                <span style="font-size:14px;color:var(--white);">Auto-issue violation on overtime</span>
                                <div style="font-size:12px;color:var(--gray-500);">Automatically creates a violation record when a vehicle exceeds the limit + grace period</div>
                            </div>
                        </label>
                    </div>
                </div>
            }
        </div>

        <div style="margin-top:20px;">
            <button type="submit" class="btn-efn btn-primary" style="padding:12px 28px;">
                💾 Save Duration Settings
            </button>
        </div>
    </form>
</div>
