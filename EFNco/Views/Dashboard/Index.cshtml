@model EFNco.Models.DashboardViewModel
@{
    ViewData["Title"] = "Analytics Dashboard";
}

@* ── Date Range Filter ── *@
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:16px;">
    <div>
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Analytics Dashboard</h2>
        <p style="font-size:13px;color:var(--gray-400);margin-top:2px;">
            Showing data from <strong style="color:var(--white);">@Model.DateFrom.ToString("MMM dd, yyyy")</strong>
            to <strong style="color:var(--white);">@Model.DateTo.ToString("MMM dd, yyyy")</strong>
        </p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <form asp-action="Index" method="get" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <input type="date" name="from" value="@Model.DateFrom.ToString("yyyy-MM-dd")"
                   class="form-control" style="width:160px;padding:8px 12px;font-size:13px;" />
            <span style="color:var(--gray-400);font-size:13px;">to</span>
            <input type="date" name="to" value="@Model.DateTo.ToString("yyyy-MM-dd")"
                   class="form-control" style="width:160px;padding:8px 12px;font-size:13px;" />
            <button type="submit" class="btn-efn btn-primary" style="padding:8px 16px;font-size:13px;">Apply</button>
        </form>

        @* Quick presets *@
        <div style="display:flex;gap:6px;">
            <a asp-action="Index" asp-route-from="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-to="@DateTime.Today.ToString("yyyy-MM-dd")"
               style="padding:6px 12px;border-radius:6px;font-size:12px;font-weight:600;text-decoration:none;background:var(--navy-light);color:var(--gray-300);border:1px solid var(--border);">Today</a>
            <a asp-action="Index" asp-route-from="@DateTime.Today.AddDays(-6).ToString("yyyy-MM-dd")" asp-route-to="@DateTime.Today.ToString("yyyy-MM-dd")"
               style="padding:6px 12px;border-radius:6px;font-size:12px;font-weight:600;text-decoration:none;background:var(--navy-light);color:var(--gray-300);border:1px solid var(--border);">7 Days</a>
            <a asp-action="Index" asp-route-from="@DateTime.Today.AddDays(-29).ToString("yyyy-MM-dd")" asp-route-to="@DateTime.Today.ToString("yyyy-MM-dd")"
               style="padding:6px 12px;border-radius:6px;font-size:12px;font-weight:600;text-decoration:none;background:var(--navy-light);color:var(--gray-300);border:1px solid var(--border);">30 Days</a>
        </div>

        @* PDF Export *@
        <a asp-action="ExportPdf" asp-route-from="@Model.DateFrom.ToString("yyyy-MM-dd")" asp-route-to="@Model.DateTo.ToString("yyyy-MM-dd")"
           class="btn-efn btn-outline" style="padding:8px 16px;font-size:13px;">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Export PDF
        </a>
    </div>
</div>

@* ── Top Stats ── *@
<div class="stats-grid" style="margin-bottom:28px;">
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
        </div>
        <div>
            <div class="stat-value">@Model.ActivePermits</div>
            <div class="stat-label">Active Permits</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <div>
            <div class="stat-value">@Model.PendingPermits</div>
            <div class="stat-label">Pending Approvals</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
        </div>
        <div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Registered Users</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
        </div>
        <div>
            <div class="stat-value">@Model.TodayEntries</div>
            <div class="stat-label">Today's Entries</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
        </div>
        <div>
            <div class="stat-value">@Model.CurrentlyInside</div>
            <div class="stat-label">Currently Inside</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <div>
            <div class="stat-value">@Model.ApprovalRate%</div>
            <div class="stat-label">Approval Rate</div>
        </div>
    </div>
</div>

@* ── Charts Row 1: Daily Entry/Exit + Permit Status ── *@
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:20px;">

    @* Daily Entry/Exit Line Chart *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">Daily Entry / Exit</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-top:2px;">Vehicle entries and exits per day</p>
        </div>
        <div style="position:relative;height:260px;">
            <canvas id="dailyChart"></canvas>
        </div>
    </div>

    @* Permit Status Donut *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">Permit Status</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-top:2px;">Breakdown by status</p>
        </div>
        <div style="position:relative;height:200px;display:flex;align-items:center;justify-content:center;">
            <canvas id="statusChart"></canvas>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;justify-content:center;">
            @for (int i = 0; i < Model.StatusLabels.Count; i++)
            {
                if (Model.StatusCounts[i] > 0)
                {
                    <span style="font-size:11px;color:var(--gray-300);">
                        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--status-color-@i);margin-right:4px;"></span>
                        @Model.StatusLabels[i]: @Model.StatusCounts[i]
                    </span>
                }
            }
        </div>
    </div>
</div>

@* ── Charts Row 2: Peak Hours + User Growth ── *@
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

    @* Peak Hours Bar Chart *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">Peak Hours</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-top:2px;">Today's entries by hour</p>
        </div>
        <div style="position:relative;height:220px;">
            <canvas id="peakChart"></canvas>
        </div>
    </div>

    @* User Growth Line Chart *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">User Growth</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-top:2px;">New registrations over time</p>
        </div>
        <div style="position:relative;height:220px;">
            <canvas id="userGrowthChart"></canvas>
        </div>
    </div>
</div>

@* ── Charts Row 3: Permit Type Breakdown ── *@
<div style="display:grid;grid-template-columns:1fr 2fr;gap:20px;margin-bottom:28px;">

    @* Permit Type Doughnut *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">Permit Types</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-top:2px;">Distribution by type</p>
        </div>
        <div style="position:relative;height:200px;display:flex;align-items:center;justify-content:center;">
            <canvas id="typeChart"></canvas>
        </div>
    </div>

    @* Approval Rate Bar *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">Permit Overview</h3>
            <p style="font-size:12px;color:var(--gray-400);margin-top:2px;">Total @Model.TotalPermits permits — @Model.TotalLogs gate logs in range</p>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;padding-top:8px;">
            @{
                var overviewItems = new[]
                {
                    new { Label = "Active",   Value = Model.ActivePermits,   Color = "var(--success)" },
                    new { Label = "Pending",  Value = Model.PendingPermits,  Color = "var(--warning)" },
                    new { Label = "Rejected", Value = Model.RejectedPermits, Color = "var(--danger)" },
                    new { Label = "Expired",  Value = Model.ExpiredPermits,  Color = "var(--gray-500)" },
                    new { Label = "Revoked",  Value = Model.RevokedPermits,  Color = "#f97316" },
                    new { Label = "Approval Rate", Value = 0, Color = "var(--blue-glow)" },
                };
            }
            @foreach (var item in overviewItems)
            {
                <div style="background:var(--navy);border-radius:10px;padding:16px;">
                    <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">@item.Label</div>
                    <div style="font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:@item.Color;">
                        @(item.Label == "Approval Rate" ? $"{Model.ApprovalRate}%" : item.Value.ToString())
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ── Recent Activity ── *@
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;">

    @* Recent Gate Logs *@
    <div class="efn-card" style="padding:0;overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);">
            <h3 style="font-size:15px;color:var(--white);">Recent Gate Activity</h3>
        </div>
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid var(--border);">
                    <th style="padding:10px 16px;text-align:left;font-size:11px;color:var(--gray-400);text-transform:uppercase;">Plate</th>
                    <th style="padding:10px 16px;text-align:left;font-size:11px;color:var(--gray-400);text-transform:uppercase;">Action</th>
                    <th style="padding:10px 16px;text-align:left;font-size:11px;color:var(--gray-400);text-transform:uppercase;">Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.RecentLogs)
                {
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:10px 16px;font-size:13px;font-weight:700;color:var(--white);font-family:'Syne',sans-serif;">@log.PlateNumber</td>
                        <td style="padding:10px 16px;">
                            @if (log.Action == "Entry")
                            {
                                <span class="badge" style="background:rgba(16,185,129,0.1);color:var(--success);border:1px solid rgba(16,185,129,0.2);">↓ Entry</span>
                            }
                            else
                            {
                                <span class="badge" style="background:rgba(37,99,235,0.1);color:var(--blue-glow);border:1px solid rgba(37,99,235,0.2);">↑ Exit @(log.Duration != null ? $"({log.Duration})" : "")</span>
                            }
                        </td>
                        <td style="padding:10px 16px;font-size:12px;color:var(--gray-400);">@log.Timestamp.ToString("h:mm tt")</td>
                    </tr>
                }
                @if (!Model.RecentLogs.Any())
                {
                    <tr><td colspan="3" style="padding:24px;text-align:center;font-size:13px;color:var(--gray-500);">No gate activity yet</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* Recent Permits *@
    <div class="efn-card" style="padding:0;overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);">
            <h3 style="font-size:15px;color:var(--white);">Recent Permits</h3>
        </div>
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid var(--border);">
                    <th style="padding:10px 16px;text-align:left;font-size:11px;color:var(--gray-400);text-transform:uppercase;">Applicant</th>
                    <th style="padding:10px 16px;text-align:left;font-size:11px;color:var(--gray-400);text-transform:uppercase;">Plate</th>
                    <th style="padding:10px 16px;text-align:left;font-size:11px;color:var(--gray-400);text-transform:uppercase;">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var permit in Model.RecentPermits)
                {
                    var sc = permit.Status switch {
                        "Approved" => "background:rgba(16,185,129,0.1);color:#6ee7b7;border:1px solid rgba(16,185,129,0.2)",
                        "Pending"  => "background:rgba(245,158,11,0.1);color:#fcd34d;border:1px solid rgba(245,158,11,0.2)",
                        "Rejected" => "background:rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.2)",
                        "Revoked"  => "background:rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.2)",
                        _ => "background:rgba(100,116,139,0.1);color:#94a3b8;border:1px solid rgba(100,116,139,0.2)"
                    };
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:10px 16px;font-size:13px;color:var(--white);">@permit.ApplicantName</td>
                        <td style="padding:10px 16px;font-size:13px;font-weight:700;color:var(--gray-300);font-family:'Syne',sans-serif;">@permit.PlateNumber</td>
                        <td style="padding:10px 16px;"><span class="badge" style="@sc">@permit.Status</span></td>
                    </tr>
                }
                @if (!Model.RecentPermits.Any())
                {
                    <tr><td colspan="3" style="padding:24px;text-align:center;font-size:13px;color:var(--gray-500);">No permits yet</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    Chart.defaults.color = '#94a3b8';
    Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';
    Chart.defaults.font.family = "'DM Sans', sans-serif";

    // ── Daily Entry/Exit Line Chart ──
    new Chart(document.getElementById('dailyChart'), {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyLabels)),
            datasets: [
                {
                    label: 'Entries',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyEntries)),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.08)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3,
                    pointBackgroundColor: '#10b981'
                },
                {
                    label: 'Exits',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyExits)),
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59,130,246,0.08)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3,
                    pointBackgroundColor: '#3b82f6'
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'top' } },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } }
            }
        }
    });

    // ── Permit Status Donut ──
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusLabels)),
            datasets: [{
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusCounts)),
                backgroundColor: ['#10b981','#f59e0b','#ef4444','#64748b','#f97316'],
                borderWidth: 2,
                borderColor: '#111827'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            cutout: '65%'
        }
    });

    // ── Peak Hours Bar Chart ──
    new Chart(document.getElementById('peakChart'), {
        type: 'bar',
        data: {
            labels: Array.from({length: 24}, (_, i) => i + ':00'),
            datasets: [{
                label: 'Entries',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HourlyEntries)),
                backgroundColor: 'rgba(37,99,235,0.6)',
                borderColor: '#2563eb',
                borderWidth: 1,
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });

    // ── User Growth Line Chart ──
    new Chart(document.getElementById('userGrowthChart'), {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UserGrowthLabels)),
            datasets: [{
                label: 'New Users',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UserGrowthCounts)),
                borderColor: '#06b6d4',
                backgroundColor: 'rgba(6,182,212,0.08)',
                fill: true,
                tension: 0.4,
                pointRadius: 3,
                pointBackgroundColor: '#06b6d4'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });

    // ── Permit Type Doughnut ──
    new Chart(document.getElementById('typeChart'), {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PermitTypeLabels)),
            datasets: [{
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PermitTypeCounts)),
                backgroundColor: ['#2563eb','#06b6d4','#8b5cf6'],
                borderWidth: 2,
                borderColor: '#111827'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { padding: 12, font: { size: 11 } } } },
            cutout: '60%'
        }
    });
</script>
}
