@model EFNco.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout"; // or your existing login layout
}

<div style="max-width:420px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:28px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Forgot Password</h2>
        <p style="color:var(--gray-400);font-size:14px;margin-top:6px;">
            Enter your email and we'll send you a reset link.
        </p>
    </div>

    <div class="efn-card">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:16px;"></div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group" style="margin-bottom:16px;">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="your@email.com" autofocus />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            <button type="submit" class="btn-efn btn-primary" style="width:100%;padding:12px;">
                Send Reset Link
            </button>
        </form>

        <div style="text-align:center;margin-top:16px;">
            <a asp-action="Login" style="font-size:13px;color:var(--gray-400);">← Back to Login</a>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
 }
