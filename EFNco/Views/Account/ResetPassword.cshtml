@model EFNco.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div style="max-width:420px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:28px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Set New Password</h2>
        <p style="color:var(--gray-400);font-size:14px;margin-top:6px;">Choose a strong password for your account.</p>
    </div>

    <div class="efn-card">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:16px;"></div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Token" type="hidden" />
            <input asp-for="Email" type="hidden" />

            <div class="form-group" style="margin-bottom:14px;">
                <label asp-for="Password" class="form-label">New Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" autofocus />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>
            <div class="form-group" style="margin-bottom:20px;">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>
            <button type="submit" class="btn-efn btn-primary" style="width:100%;padding:12px;">Reset Password</button>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
 }
