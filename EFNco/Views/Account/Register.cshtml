@model EFNco.Models.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — EFNco</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="auth-page">
        <!-- Left Panel -->
        <div class="auth-left">
            <div class="auth-grid"></div>
            <div class="auth-brand">
                <div class="auth-brand-icon">EF</div>
                <div>
                    <div class="auth-brand-name">EFNco</div>
                    <div class="auth-brand-tagline">Efficient Facility Network Control</div>
                </div>
            </div>

            <h1 class="auth-headline">
                Join EFNco's<br><span>Smart Parking</span><br>Ecosystem
            </h1>
            <p class="auth-desc">
                Create your account to apply for digital parking permits, manage vehicle access,
                and enjoy a seamless, sticker-free experience.
            </p>

            <div class="auth-features">
                <div class="auth-feature">
                    <div class="auth-feature-dot"></div>
                    Apply for permits entirely online
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-dot"></div>
                    Get notified on approvals & renewals
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-dot"></div>
                    Authorize trusted persons to use your vehicle
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-dot"></div>
                    Receive instant violation alerts
                </div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="auth-right">
            <div class="auth-form-title">Create Account</div>
            <div class="auth-form-subtitle">Fill in your details to get started with EFNco.</div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                    </svg>
                    <div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                        <span asp-validation-for="FirstName" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="dela Cruz" />
                        <span asp-validation-for="LastName" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="juan@university.edu.ph" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Department / Unit <span style="color:var(--gray-500)">(Optional)</span></label>
                    <input asp-for="Department" class="form-control" placeholder="e.g. College of Engineering" />
                    <span asp-validation-for="Department" class="field-validation-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <div style="margin-bottom:24px;">
                    <p style="font-size:12px;color:var(--gray-500);">
                        Password must be at least 6 characters and include uppercase, lowercase, and a number.
                    </p>
                </div>

                <button type="submit" class="btn-auth">
                    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                    Create Account
                </button>
            </form>

            <div class="auth-footer-link" style="margin-top:28px;">
                Already have an account? <a asp-action="Login">Sign in</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
