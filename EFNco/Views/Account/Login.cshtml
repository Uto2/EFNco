@model EFNco.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — EFNco</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="auth-page">
    <!-- Left Panel -->
    <div class="auth-left">
        <div class="auth-grid"></div>
        <div class="auth-brand">
            <div class="auth-brand-icon">EF</div>
            <div>
                <div class="auth-brand-name">EFNco</div>
                <div class="auth-brand-tagline">Efficient Facility Network Control</div>
            </div>
        </div>

        <h1 class="auth-headline">
            Modern Parking<br><span>Access Control</span><br>for Your Facility
        </h1>
        <p class="auth-desc">
            Replace outdated sticker-based verification with secure digital permits,
            real-time monitoring, and automated gate management.
        </p>

        <div class="auth-features">
            <div class="auth-feature">
                <div class="auth-feature-dot"></div>
                Digital QR & RFID permit management
            </div>
            <div class="auth-feature">
                <div class="auth-feature-dot"></div>
                Real-time vehicle entry & exit tracking
            </div>
            <div class="auth-feature">
                <div class="auth-feature-dot"></div>
                Automated violation alerts & enforcement
            </div>
            <div class="auth-feature">
                <div class="auth-feature-dot"></div>
                Centralized admin dashboard & analytics
            </div>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="auth-right">
        <div class="auth-form-title">Welcome back</div>
        <div class="auth-form-subtitle">Sign in to your EFNco account to continue.</div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <div>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="form-group">
                <label class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:28px;display:flex;justify-content:space-between;align-items:center;">
                <label class="checkbox-row" style="margin:0;">
                    <input asp-for="RememberMe" type="checkbox" />
                    Keep me signed in
                </label>
                <a asp-action="ForgotPassword" style="font-size:13px;color:var(--blue-light);text-decoration:none;">Forgot password?</a>
            </div>

            <button type="submit" class="btn-auth">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                </svg>
                Sign In
            </button>
        </form>

        <div class="auth-footer-link" style="margin-top:28px;">
            Don't have an account? <a asp-action="Register">Create one</a>
        </div>

        <!-- Admin credentials hint -->
        <div style="margin-top:28px;padding:14px 16px;background:rgba(37,99,235,0.06);border:1px solid rgba(37,99,235,0.15);border-radius:var(--radius-sm);">
            <div style="font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--blue-glow);margin-bottom:8px;">
                🔐 Default Admin Account
            </div>
            <div style="font-size:13px;color:var(--gray-300);display:flex;flex-direction:column;gap:4px;">
                <div>Email: <span style="color:var(--white);font-weight:500;">admin@efnco.com</span></div>
                <div>Password: <span style="color:var(--white);font-weight:500;">Admin@123</span></div>
            </div>
            <div style="font-size:11px;color:var(--gray-500);margin-top:8px;">Remove this hint before production deployment.</div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
