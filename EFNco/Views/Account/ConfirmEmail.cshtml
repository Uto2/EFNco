@{
    ViewData["Title"] = "Email Confirmation";
    bool success = ViewBag.Success == true;
}

<div style="max-width:420px;margin:0 auto;text-align:center;">
    <div class="efn-card" style="padding:40px 32px;">
        @if (success)
        {
            <div style="width:64px;height:64px;border-radius:50%;background:rgba(16,185,129,0.1);border:2px solid rgba(16,185,129,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
                <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#6ee7b7" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h2 style="font-size:20px;font-family:'Syne',sans-serif;margin-bottom:10px;color:#6ee7b7;">Email Confirmed!</h2>
            <p style="color:var(--gray-400);font-size:14px;">Your account has been activated. You can now log in.</p>
            <a asp-action="Login" class="btn-efn btn-primary" style="margin-top:20px;display:inline-block;padding:10px 28px;">Log In</a>
        }
        else
        {
            <div style="width:64px;height:64px;border-radius:50%;background:rgba(239,68,68,0.1);border:2px solid rgba(239,68,68,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
                <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#fca5a5" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
            <h2 style="font-size:20px;font-family:'Syne',sans-serif;margin-bottom:10px;color:#fca5a5;">Confirmation Failed</h2>
            <p style="color:var(--gray-400);font-size:14px;">The confirmation link is invalid or has expired. Please register again or contact support.</p>
            <a asp-action="Login" class="btn-efn btn-outline" style="margin-top:20px;display:inline-block;">Back to Login</a>
        }
    </div>
</div>
