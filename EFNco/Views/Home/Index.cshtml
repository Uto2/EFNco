@{
    ViewData["Title"] = "Dashboard";
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
        </div>
        <div>
            <div class="stat-value">@ViewBag.ActivePermits</div>
            <div class="stat-label">Active Permits</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon amber">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div>
            <div class="stat-value">@ViewBag.PendingPermits</div>
            <div class="stat-label">Pending Approvals</div>
        </div>
    </div>

    @* Instruction 5: Violations Stat Card *@
    <div class="stat-card">
        <div class="stat-icon red">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <div>
            <div class="stat-value">@ViewBag.TotalViolations</div>
            <div class="stat-label">Unpaid Violations</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon cyan">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
        </div>
        <div>
            <div class="stat-value">@ViewBag.TodayEntries</div>
            <div class="stat-label">Today's Entries</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon amber">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </div>
        <div>
            <div class="stat-value">@ViewBag.CurrentlyInside</div>
            <div class="stat-label">Currently Inside</div>
        </div>
    </div>
</div>

<div class="efn-card" style="max-width:720px; margin-top:24px;">
    <div style="display:flex;align-items:flex-start;gap:20px;">
        <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,var(--blue),var(--cyan));display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
        </div>
        <div>
            <h2 style="font-size:20px;margin-bottom:6px;">Welcome back, @ViewBag.UserName! 👋</h2>
            <p style="color:var(--gray-400);font-size:14px;line-height:1.7;">
                You're signed in as <span class="badge badge-@(ViewBag.Role?.ToString().ToLower() == "admin" ? "admin" : "user")">@ViewBag.Role</span>.
                EFNco is your digital hub for parking permit applications and vehicle monitoring.
            </p>
            <div style="margin-top:20px;display:flex;gap:12px;flex-wrap:wrap;">
                <a asp-controller="Permit" asp-action="MyPermits" class="btn-efn btn-primary">My Permits</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Permits" class="btn-efn btn-outline">Review Permits</a>
                    <a asp-controller="Admin" asp-action="AdminViolations" class="btn-efn btn-outline">Violations</a>
                }
            </div>
        </div>
    </div>
</div>