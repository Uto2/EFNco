@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EFNco — Efficient Facility Network Control</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        .feature-card {
            transition: all 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5), 0 0 20px rgba(37,99,235,0.15);
            border-color: rgba(37,99,235,0.4);
        }
        .step {
            transition: all 0.3s ease;
        }
        .step:hover {
            transform: translateX(8px);
        }
        .hero-title {
            animation: slideDownFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .hero-subtitle {
            opacity: 0;
            animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: 0.2s;
        }
        .hero-cta {
            opacity: 0;
            animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: 0.4s;
        }

        /* Interactive Architecture Styles */
        .architecture-container {
            position: relative;
            max-width: 900px;
            margin: 60px auto;
            padding: 40px;
            background: linear-gradient(135deg, rgba(14,23,38,0.6) 0%, rgba(10,15,30,0.8) 100%);
            border: 1px solid rgba(37,99,235,0.2);
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            text-align: center;
        }
        .arch-title {
            font-family: 'Syne', sans-serif;
            font-size: 24px;
            color: var(--white);
            margin-bottom: 40px;
        }
        .arch-map {
            position: relative;
            width: 100%;
            height: 200px;
            background: radial-gradient(circle, rgba(37,99,235,0.05) 0%, transparent 70%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: space-around;
        }
        .hotspot {
            position: relative;
            width: 64px;
            height: 64px;
            background: var(--navy-mid);
            border: 2px solid var(--blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
            transition: all 0.3s ease;
        }
        .hotspot::before {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            border: 1px solid rgba(37,99,235,0.4);
            animation: pulse-ring 2s infinite;
            pointer-events: none;
        }
        .hotspot:hover {
            transform: scale(1.1);
            background: var(--blue);
            box-shadow: 0 0 20px rgba(37,99,235,0.6);
        }
        .hotspot-tooltip {
            position: absolute;
            bottom: 120%;
            left: 50%;
            transform: translateX(-50%) translateY(20px) scale(0.9);
            width: 280px;
            background: rgba(14,23,38,0.95);
            border: 1px solid rgba(6,182,212,0.3);
            border-radius: 12px;
            padding: 16px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            text-align: left;
            z-index: 20;
            pointer-events: none;
            backdrop-filter: blur(10px);
        }
        .hotspot:hover .hotspot-tooltip {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0) scale(1);
        }
        .tooltip-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--cyan);
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .tooltip-desc {
            font-size: 13px;
            color: var(--gray-300);
            line-height: 1.5;
        }
        /* Connection lines */
        .arch-line {
            position: absolute;
            top: 50%;
            left: 15%;
            right: 15%;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(37,99,235,0.5), transparent);
            z-index: 0;
            transform: translateY(-50%);
        }
        .arch-line::after {
            content: '';
            position: absolute;
            top: -2px;
            left: 0;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--cyan);
            box-shadow: 0 0 10px var(--cyan);
            animation: moveDot 3s linear infinite;
        }
        @@keyframes moveDot {
            0% { left: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { left: 100%; opacity: 0; }
        }
    </style>
</head>
<body>
<div class="landing-page">

    <!-- NAV -->
    <nav class="landing-nav">
        <a class="nav-logo" href="#">
            <div class="nav-logo-icon">EF</div>
            <span class="nav-logo-name">EFNco</span>
        </a>
        <div class="nav-links">
            <a asp-controller="Account" asp-action="Login" class="nav-btn-login">Sign In</a>
            <a asp-controller="Account" asp-action="Register" class="nav-btn-register">Get Started</a>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-glow"></div>
        <div class="hero-grid"></div>
        <div class="hero-badge">
            <div class="hero-badge-dot"></div>
            Digital Parking &amp; Access Management
        </div>
        <h1 class="hero-title">
            The Smarter Way to<br>
            Manage <span>Facility Access</span>
        </h1>
        <p class="hero-subtitle">
            EFNco replaces outdated sticker-based parking systems with secure digital permits,
            real-time gate verification, and intelligent analytics — built for universities,
            residential communities, and office facilities.
        </p>
        <div class="hero-cta">
            <a asp-controller="Account" asp-action="Register" class="cta-primary">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                </svg>
                Create Free Account
            </a>
            <a asp-controller="Account" asp-action="Login" class="cta-secondary">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                </svg>
                Sign In
            </a>
        </div>
    </section>

    <!-- STATS STRIP -->
    <div class="stats-strip">
        <div class="strip-stat">
            <div class="strip-stat-value"><span>100%</span></div>
            <div class="strip-stat-label">Digital Permit Processing</div>
        </div>
        <div class="strip-stat">
            <div class="strip-stat-value"><span>0</span> Stickers</div>
            <div class="strip-stat-label">No Physical Tags Needed</div>
        </div>
        <div class="strip-stat">
            <div class="strip-stat-value">Real-<span>Time</span></div>
            <div class="strip-stat-label">Gate Monitoring</div>
        </div>
        <div class="strip-stat">
            <div class="strip-stat-value"><span>24/7</span></div>
            <div class="strip-stat-label">Automated Access Control</div>
        </div>
    </div>

    <!-- INTERACTIVE ARCHITECTURE -->
    <section class="reveal" style="padding: 0 20px;">
        <div class="architecture-container">
            <h2 class="arch-title">Explore the EFNco Ecosystem</h2>
            <div class="arch-map">
                <div class="arch-line"></div>
                
                <!-- Node 1 -->
                <div class="hotspot">
                    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <div class="hotspot-tooltip">
                        <div class="tooltip-title">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            The User Portal
                        </div>
                        <div class="tooltip-desc" style="font-size:12px; line-height:1.6;">Users log in securely to their personalized dashboard to manage registered vehicles, submit verifiable OR/CR documentation, and receive an instant, cryptographically-secure dynamic QR code permit. Say goodbye to the days of long queues and waiting weeks for a fragile plastic sticker to be printed!</div>
                    </div>
                </div>

                <!-- Node 2 -->
                <div class="hotspot" style="border-color:var(--cyan);">
                    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
                    </svg>
                    <div class="hotspot-tooltip">
                        <div class="tooltip-title">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Centralized Cloud Hub
                        </div>
                        <div class="tooltip-desc" style="font-size:12px; line-height:1.6;">The beating heart of the EFNco network! All permit data, violation records, and authorization hierarchies are securely managed in our hyper-fast relational cloud database. The hub seamlessly synchronizes data in milliseconds to verify status, flag active unpaid violations, and cross-reference duration limits, ensuring absolute data integrity.</div>
                    </div>
                </div>

                <!-- Node 3 -->
                <div class="hotspot" style="border-color:var(--success);">
                    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8H3m2 4H1m18 0h.01M5 20H3m2-4H1"/>
                    </svg>
                    <div class="hotspot-tooltip">
                        <div class="tooltip-title">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Gate Control Scanner
                        </div>
                        <div class="tooltip-desc" style="font-size:12px; line-height:1.6;">Security personnel are equipped with our lightning-fast, role-specific scanner dashboard. A split-second flash of a driver's QR code instantly queries the Central Hub, logging the precise entry/exit timestamp. It automatically calculates maximum parking duration allowances, flags overstayers on the spot, and prevents unauthorized access.</div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features reveal">
        <div class="section-label">What EFNco Offers</div>
        <div class="section-title">Everything your facility needs</div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon blue">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div class="feature-title">Digital Permit Management</div>
                <div class="feature-desc">Apply, manage, and renew parking permits entirely online. No paperwork, no stickers, no queues.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon cyan">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8H3m2 4H1m18 0h.01M5 20H3m2-4H1"/>
                    </svg>
                </div>
                <div class="feature-title">QR &amp; RFID Verification</div>
                <div class="feature-desc">Secure digital permits verified instantly at gate entry points — no manual checking needed.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon green">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                </div>
                <div class="feature-title">Real-Time Analytics</div>
                <div class="feature-desc">Monitor vehicle entry and exit in real time. Get traffic insights to optimize your facility.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon amber">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                </div>
                <div class="feature-title">Violation Enforcement</div>
                <div class="feature-desc">Automated alerts for violations. Penalties tracked and enforced without manual intervention.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon purple">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div class="feature-title">Authorized Person Access</div>
                <div class="feature-desc">Allow trusted individuals to use a registered vehicle under verified conditions.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon rose">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="feature-title">Parking Duration Tracking</div>
                <div class="feature-desc">Automatically log and monitor how long each vehicle stays. Enforce time limits easily.</div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-section reveal">
        <div class="how-inner">
            <div class="section-label">Simple Process</div>
            <div class="section-title">How EFNco Works</div>
            <div class="steps">
                <div class="step">
                    <div class="step-num">1</div>
                    <div class="step-title">Create Account</div>
                    <div class="step-desc">Register with your email and department. Your profile is verified by the facility admin.</div>
                </div>
                <div class="step">
                    <div class="step-num">2</div>
                    <div class="step-title">Apply for Permit</div>
                    <div class="step-desc">Submit your vehicle details and permit type online. Track your application in real time.</div>
                </div>
                <div class="step">
                    <div class="step-num">3</div>
                    <div class="step-title">Get Digital Permit</div>
                    <div class="step-desc">Once approved, receive your QR-based digital permit. Your phone is your pass.</div>
                </div>
                <div class="step">
                    <div class="step-num">4</div>
                    <div class="step-title">Drive In &amp; Out</div>
                    <div class="step-desc">Scan at the gate for instant automated verification. Entry and exit logged automatically.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section reveal">
        <h2>Ready to modernize your parking?</h2>
        <p>Join EFNco today and experience hassle-free, digital facility access management.</p>
        <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
            <a asp-controller="Account" asp-action="Register" class="cta-primary">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                </svg>
                Create Account — It's Free
            </a>
            <a asp-controller="Account" asp-action="Login" class="cta-secondary">
                Already have an account? Sign In →
            </a>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="landing-footer">
        <span>© @DateTime.Now.Year <strong style="color:var(--gray-300);">EFNco</strong> — Efficient Facility Network Control</span>
        <div style="display:flex;gap:20px;">
            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            <a asp-controller="Account" asp-action="Login">Sign In</a>
            <a asp-controller="Account" asp-action="Register">Register</a>
        </div>
    </footer>

</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    // Scroll reveal animation
    document.addEventListener("DOMContentLoaded", function() {
        const reveals = document.querySelectorAll(".reveal");
        
        const revealOptions = {
            threshold: 0.1,
            rootMargin: "0px 0px -50px 0px"
        };
        
        const revealOnScroll = new IntersectionObserver(function(entries, observer) {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("active");
                observer.unobserve(entry.target);
            });
        }, revealOptions);
        
        reveals.forEach(reveal => {
            revealOnScroll.observe(reveal);
        });
        
        // Stagger stats
        document.querySelectorAll('.strip-stat').forEach((stat, i) => {
            stat.style.opacity = '0';
            stat.style.animation = `slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards ${0.6 + (i * 0.1)}s`;
        });
    });
</script>
</body>
</html>
