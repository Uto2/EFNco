@model List<EFNco.Models.AuthorizedPerson>
@{
    ViewData["Title"] = "Authorized Persons";
    var permit = ViewBag.Permit as EFNco.Models.ParkingPermit;
}

<div style="max-width:680px;">
    <div style="margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
        <div>
            <a asp-action="Details" asp-controller="Permit" asp-route-id="@permit!.Id"
               class="btn-efn btn-outline" style="padding:7px 14px;font-size:13px;">← Back to Permit</a>
        </div>
        <h2 style="font-size:18px;font-family:'Syne',sans-serif;">Authorized Persons</h2>
        <a asp-action="Add" asp-route-permitId="@permit!.Id" class="btn-efn btn-primary">
            + Add Person
        </a>
    </div>

    <div class="alert alert-warning" style="margin-bottom:20px;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>Authorized persons can use this permit at the gate. They must present valid ID matching the registered ID number.</span>
    </div>

    @if (!Model.Any())
    {
        <div class="efn-card" style="text-align:center;padding:48px 24px;">
            <p style="color:var(--gray-400);font-size:14px;margin-bottom:16px;">No authorized persons added yet.</p>
            <a asp-action="Add" asp-route-permitId="@permit!.Id" class="btn-efn btn-primary">Add First Person</a>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:14px;">
            @foreach (var p in Model)
            {
                <div class="efn-card" style="padding:18px 20px;">
                    <div style="display:flex;gap:16px;align-items:center;">

                        @* Photo *@
                        <div style="width:56px;height:56px;border-radius:50%;overflow:hidden;background:var(--navy-light);flex-shrink:0;border:2px solid var(--border);">
                            @if (p.PhotoData != null)
                            {
                                <img src="/AuthorizedPerson/Photo/@p.Id"
                                     alt="@p.FullName"
                                     style="width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--gray-500)" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                    </svg>
                                </div>
                            }
                        </div>

                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                                <span style="font-size:15px;font-weight:600;color:var(--white);">@p.FullName</span>
                                @if (!p.IsActive)
                                {
                                    <span class="badge" style="background:rgba(239,68,68,0.1);color:#fca5a5;border:1px solid rgba(239,68,68,0.25);font-size:11px;">Inactive</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:rgba(16,185,129,0.1);color:#6ee7b7;border:1px solid rgba(16,185,129,0.25);font-size:11px;">Active</span>
                                }
                            </div>
                            <div style="font-size:13px;color:var(--gray-400);margin-top:3px;">@p.Relationship</div>
                            <div style="display:flex;gap:16px;margin-top:6px;flex-wrap:wrap;">
                                <span style="font-size:12px;color:var(--gray-500);">ID: <strong style="color:var(--gray-300);">@p.IdNumber</strong></span>
                                @if (!string.IsNullOrEmpty(p.ContactNumber))
                                {
                                    <span style="font-size:12px;color:var(--gray-500);">📞 @p.ContactNumber</span>
                                }
                                @if (!string.IsNullOrEmpty(p.Email))
                                {
                                    <span style="font-size:12px;color:var(--gray-500);">✉ @p.Email</span>
                                }
                            </div>
                        </div>

                        <div style="display:flex;flex-direction:column;gap:8px;flex-shrink:0;">
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn-efn btn-outline" style="padding:5px 14px;font-size:12px;">Edit</a>

                            @if (p.IsActive)
                            {
                                <form asp-action="Deactivate" asp-route-id="@p.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-efn btn-danger"
                                            style="padding:5px 14px;font-size:12px;width:100%;"
                                            onclick="return confirm('Deactivate @p.FullName?')">
                                        Deactivate
                                    </button>
                                </form>
                            }

                            <form asp-action="Delete" asp-route-id="@p.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-efn btn-outline"
                                        style="padding:5px 14px;font-size:12px;width:100%;color:var(--danger);"
                                        onclick="return confirm('Permanently remove @p.FullName?')">
                                    Remove
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
