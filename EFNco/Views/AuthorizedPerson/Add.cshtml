@model EFNco.Models.AuthorizedPersonViewModel
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Authorized Person" : "Add Authorized Person";
}

<div style="max-width:560px;">
    <div style="margin-bottom:20px;">
        <a asp-action="Index" asp-route-permitId="@Model.PermitId"
           class="btn-efn btn-outline" style="padding:7px 14px;font-size:13px;">← Back</a>
    </div>

    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);">
                👤 @(isEdit ? "Edit Authorized Person" : "Add Authorized Person")
            </h3>
            <p style="font-size:13px;color:var(--gray-400);margin-top:4px;">
                This person will be allowed to use the permit at the gate.
            </p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:16px;"></div>

        <form method="post"
              asp-action="@(isEdit ? "Edit" : "Add")"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PermitId" />

            @* Photo Upload *@
            <div class="form-group" style="margin-bottom:20px;text-align:center;">
                <div id="photoPreviewWrap" style="width:90px;height:90px;border-radius:50%;overflow:hidden;background:var(--navy-light);border:2px dashed var(--border);margin:0 auto 10px;cursor:pointer;display:flex;align-items:center;justify-content:center;"
                     onclick="document.getElementById('photoInput').click()">
                    @if (Model.HasPhoto && isEdit)
                    {
                        <img id="photoPreviewImg" src="/AuthorizedPerson/Photo/@Model.Id"
                             style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <svg id="photoPlaceholder" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="var(--gray-500)" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        <img id="photoPreviewImg" src="" style="width:100%;height:100%;object-fit:cover;display:none;" />
                    }
                </div>
                <p style="font-size:12px;color:var(--gray-500);">Click to upload photo (JPG/PNG)</p>
                <input type="file" id="photoInput" asp-for="PhotoFile" accept=".jpg,.jpeg,.png" style="display:none;"
                       onchange="previewPhoto(this)" />
                <span asp-validation-for="PhotoFile" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FullName" class="form-label">Full Name <span style="color:var(--danger)">*</span></label>
                    <input asp-for="FullName" class="form-control" placeholder="e.g. Juan Dela Cruz" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Relationship" class="form-label">Relationship <span style="color:var(--danger)">*</span></label>
                    <select asp-for="Relationship" class="form-control">
                        <option value="">— Select —</option>
                        <option>Spouse</option>
                        <option>Parent</option>
                        <option>Sibling</option>
                        <option>Child</option>
                        <option>Colleague</option>
                        <option>Driver</option>
                        <option>Other</option>
                    </select>
                    <span asp-validation-for="Relationship" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="IdNumber" class="form-label">ID Number <span style="color:var(--danger)">*</span></label>
                    <input asp-for="IdNumber" class="form-control" placeholder="e.g. 2021-00123" />
                    <span asp-validation-for="IdNumber" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ContactNumber" class="form-label">Contact Number <span style="color:var(--gray-500)">(Optional)</span></label>
                    <input asp-for="ContactNumber" class="form-control" placeholder="e.g. 09XX-XXX-XXXX" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email <span style="color:var(--gray-500)">(Optional)</span></label>
                <input asp-for="Email" class="form-control" placeholder="e.g. person@email.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            @if (isEdit)
            {
                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                        <input asp-for="IsActive" type="checkbox" style="width:16px;height:16px;" />
                        <span class="form-label" style="margin:0;">Active (can use the permit)</span>
                    </label>
                </div>
            }

            <div style="display:flex;gap:12px;margin-top:8px;">
                <button type="submit" class="btn-efn btn-primary">
                    @(isEdit ? "Save Changes" : "Add Person")
                </button>
                <a asp-action="Index" asp-route-permitId="@Model.PermitId" class="btn-efn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewPhoto(input) {
            if (!input.files[0]) return;
            const reader = new FileReader();
            reader.onload = e => {
                const img = document.getElementById('photoPreviewImg');
                const ph  = document.getElementById('photoPlaceholder');
                img.src           = e.target.result;
                img.style.display = 'block';
                if (ph) ph.style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}
