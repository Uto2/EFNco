@model EFNco.Models.LogViolationViewModel
@{
    ViewData["Title"] = "Log Violation";
}

<div style="max-width:540px;">
    <div style="margin-bottom:24px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Log Violation</h2>
        <p style="color:var(--gray-400);font-size:14px;margin-top:4px;">Issue a parking violation and notify the vehicle owner.</p>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger" style="margin-bottom:16px;">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>• @error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Log" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PermitId" value="@Model.PermitId" />
        <input type="hidden" name="ViolatorUserId" value="@Model.ViolatorUserId" />

        <div class="efn-card" style="margin-bottom:20px;">
            <div class="efn-card-header">
                <h3 style="font-size:15px;color:var(--white);">Vehicle & Violation</h3>
            </div>

            <div class="form-group">
                <label class="form-label">Plate Number <span style="color:var(--danger)">*</span></label>
                <input type="text" name="PlateNumber" value="@Model.PlateNumber"
                       class="form-control"
                       placeholder="e.g. ABC 1234"
                       style="text-transform:uppercase;font-size:18px;font-weight:700;font-family:'Syne',sans-serif;letter-spacing:2px;"
                       @(Model.PlateNumber != null ? "readonly" : "") />
                <span asp-validation-for="PlateNumber" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Violation Type <span style="color:var(--danger)">*</span></label>
                <select name="ViolationType" id="violationTypeSelect" class="form-control" onchange="updateFine(this)">
                    <option value="">— Select violation type —</option>
                    <option value="Overstay">Overstay — ₱500.00</option>
                    <option value="NoPermit">No Permit — ₱1,000.00</option>
                    <option value="ExpiredPermit">Expired Permit — ₱750.00</option>
                    <option value="UnauthorizedVehicle">Unauthorized Vehicle — ₱1,500.00</option>
                    <option value="WrongParkingZone">Wrong Parking Zone — ₱500.00</option>
                </select>
                <span asp-validation-for="ViolationType" class="field-validation-error"></span>
            </div>

            @* Fine Preview *@
            <div id="finePreview" style="display:none;margin-top:4px;padding:14px 16px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:8px;">
                <div style="font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Preset Fine Amount</div>
                <div id="fineAmount" style="font-size:24px;font-weight:800;color:var(--danger);font-family:'Syne',sans-serif;"></div>
            </div>

            <div class="form-group" style="margin-top:16px;">
                <label class="form-label">Notes <span style="color:var(--gray-500)">(Optional)</span></label>
                <textarea name="Notes" class="form-control" rows="3"
                          placeholder="Additional details about the violation...">@Model.Notes</textarea>
            </div>
        </div>

        <div class="alert alert-warning" style="margin-bottom:20px;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>The vehicle owner will be notified via <strong>in-app notification and email</strong> once this violation is logged.</span>
        </div>

        <div style="display:flex;gap:12px;">
            <button type="submit" class="btn-efn" style="background:var(--danger);color:white;padding:12px 24px;font-size:15px;font-weight:600;">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Issue Violation
            </button>
            <a href="javascript:history.back()" class="btn-efn btn-outline">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    const fines = {
        'Overstay': '₱500.00',
        'NoPermit': '₱1,000.00',
        'ExpiredPermit': '₱750.00',
        'UnauthorizedVehicle': '₱1,500.00',
        'WrongParkingZone': '₱500.00'
    };

    function updateFine(select) {
        const val = select.value;
        const preview = document.getElementById('finePreview');
        const amount = document.getElementById('fineAmount');
        if (val && fines[val]) {
            preview.style.display = 'block';
            amount.textContent = fines[val];
        } else {
            preview.style.display = 'none';
        }
    }
</script>
}
