@model List<EFNco.Models.UserListViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
    <div>
        <h2 style="font-size:18px;color:var(--white);">All Users</h2>
        <p style="font-size:13px;color:var(--gray-400);margin-top:2px;">@Model.Count total registered accounts</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="margin-bottom:20px;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" style="margin-bottom:20px;">@TempData["Error"]</div>
}

<div class="efn-card" style="padding:0;overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;">
        <thead>
            <tr style="border-bottom:1px solid var(--border);">
                <th style="padding:14px 20px;text-align:left;font-size:11px;font-weight:600;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;">User</th>
                <th style="padding:14px 20px;text-align:left;font-size:11px;font-weight:600;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;">Department</th>
                <th style="padding:14px 20px;text-align:left;font-size:11px;font-weight:600;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;">Role</th>
                <th style="padding:14px 20px;text-align:left;font-size:11px;font-weight:600;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;">Status</th>
                <th style="padding:14px 20px;text-align:left;font-size:11px;font-weight:600;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;">Joined</th>
                <th style="padding:14px 20px;text-align:right;font-size:11px;font-weight:600;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr style="border-bottom:1px solid var(--border);transition:background 0.15s;" onmouseover="this.style.background='var(--navy-light)'" onmouseout="this.style.background=''">
                    <td style="padding:14px 20px;">
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--cyan));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:white;flex-shrink:0;">
                                @(user.FullName.Length > 0 ? user.FullName[0].ToString().ToUpper() : "?")
                            </div>
                            <div>
                                <div style="font-size:14px;font-weight:500;color:var(--white);">@user.FullName</div>
                                <div style="font-size:12px;color:var(--gray-400);">@user.Email</div>
                            </div>
                        </div>
                    </td>
                    <td style="padding:14px 20px;font-size:13px;color:var(--gray-300);">@(user.Department ?? "—")</td>
                    <td style="padding:14px 20px;">
                        <span class="badge @(user.Role == "Admin" ? "badge-admin" : "badge-user")">@user.Role</span>
                    </td>
                    <td style="padding:14px 20px;">
                        @if (user.IsActive)
                        {
                            <span class="badge" style="background:rgba(16,185,129,0.1);color:var(--success);border:1px solid rgba(16,185,129,0.2);">Active</span>
                        }
                        else
                        {
                            <span class="badge" style="background:rgba(239,68,68,0.1);color:var(--danger);border:1px solid rgba(239,68,68,0.2);">Inactive</span>
                        }
                    </td>
                    <td style="padding:14px 20px;font-size:13px;color:var(--gray-400);">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td style="padding:14px 20px;text-align:right;">
                        <div style="display:flex;gap:8px;justify-content:flex-end;">
                            <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn-efn btn-outline" style="padding:6px 12px;font-size:12px;">View</a>
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn-efn btn-primary" style="padding:6px 12px;font-size:12px;">Edit</a>
                            <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn-efn btn-danger" style="padding:6px 12px;font-size:12px;">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
