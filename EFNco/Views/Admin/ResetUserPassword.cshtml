@{
    ViewData["Title"] = "Reset Password";
}

<div style="max-width:440px;">
    <div style="margin-bottom:20px;">
        <a asp-action="Users" class="btn-efn btn-outline" style="padding:7px 14px;font-size:13px;">← Back to Users</a>
    </div>

    <div class="efn-card">
        <div class="efn-card-header">
            <h2 style="font-size:18px;">Reset Password</h2>
            <p style="font-size:13px;color:var(--gray-400);margin-top:4px;">Setting new password for: <strong style="color:var(--white);">@ViewBag.UserName</strong></p>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="ResetUserPassword" asp-route-id="@ViewBag.UserId" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">New Password</label>
                <input name="newPassword" type="password" class="form-control" placeholder="Min. 6 characters" required minlength="6" />
            </div>

            <div style="display:flex;gap:10px;margin-top:8px;">
                <button type="submit" class="btn-efn btn-primary">Reset Password</button>
                <a asp-action="Users" class="btn-efn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
