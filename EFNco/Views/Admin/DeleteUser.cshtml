@model EFNco.Models.ApplicationUser
@{
    ViewData["Title"] = "Delete User";
}

<div style="max-width:480px;">
    <div style="margin-bottom:20px;">
        <a asp-action="Users" class="btn-efn btn-outline" style="padding:7px 14px;font-size:13px;">← Back to Users</a>
    </div>

    <div class="efn-card">
        <div style="text-align:center;padding:16px 0 24px;">
            <div style="width:64px;height:64px;border-radius:50%;background:rgba(239,68,68,0.1);border:2px solid rgba(239,68,68,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="var(--danger)" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
            </div>
            <h2 style="font-size:20px;margin-bottom:8px;">Delete User</h2>
            <p style="color:var(--gray-400);font-size:14px;line-height:1.6;">
                Are you sure you want to permanently delete<br>
                <strong style="color:var(--white);">@Model.FullName</strong> (@Model.Email)?<br>
                <span style="color:var(--danger);font-size:13px;">This action cannot be undone.</span>
            </p>
        </div>

        <div style="display:flex;gap:10px;justify-content:center;">
            <form asp-action="DeleteUser" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-efn" style="background:var(--danger);color:white;padding:10px 24px;">Yes, Delete</button>
            </form>
            <a asp-action="Users" class="btn-efn btn-outline" style="padding:10px 24px;">Cancel</a>
        </div>
    </div>
</div>
