@{
    ViewData["Title"] = "Gate Scanner";
}

<div style="max-width:560px;">

    <div style="margin-bottom:24px;">
        <h2 style="font-size:22px;font-family:'Syne',sans-serif;">Gate Scanner</h2>
        <p style="color:var(--gray-400);font-size:14px;margin-top:4px;">Scan a permit QR code or enter a plate number manually to verify entry/exit.</p>
    </div>

    @* ── Camera QR Scanner ── *@
    <div class="efn-card" style="margin-bottom:20px;">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);display:flex;align-items:center;gap:8px;">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--blue-glow)" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8H3m2 4H1m18 0h.01M5 20H3m2-4H1" />
                </svg>
                Camera QR Scan
            </h3>
            <p style="font-size:13px;color:var(--gray-400);margin-top:4px;">Point the camera at the permit QR code.</p>
        </div>

        <div style="position:relative;width:100%;background:var(--navy);border-radius:8px;overflow:hidden;">
            <video id="qr-video" style="width:100%;display:none;border-radius:8px;transform:scaleX(-1);" playsinline></video>
            <canvas id="qr-canvas" style="display:none;"></canvas>

            <div id="qr-placeholder" style="text-align:center;padding:48px 32px;color:var(--gray-500);">
                <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="margin:0 auto 12px;display:block;opacity:0.4;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <p style="font-size:14px;">Click "Start Camera" to begin scanning</p>
            </div>

            @* Scanning overlay *@
            <div id="scan-overlay" style="display:none;position:absolute;inset:0;pointer-events:none;">
                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:200px;height:200px;border:3px solid var(--blue-light);border-radius:12px;box-shadow:0 0 0 9999px rgba(0,0,0,0.4);"></div>
                <div style="position:absolute;bottom:12px;width:100%;text-align:center;color:white;font-size:13px;">Align QR code in the box</div>
            </div>
        </div>

        <div id="scan-status" style="display:none;margin-top:10px;" class="alert alert-success">
            ✅ QR code detected! Submitting...
        </div>

        @* ✅ Added debug box so you can see what was scanned *@
        <div id="scan-debug" style="display:none;margin-top:10px;padding:10px 14px;background:var(--navy);border-radius:8px;font-size:12px;color:var(--gray-400);word-break:break-all;">
            <strong style="color:var(--gray-300);">Scanned:</strong> <span id="scan-debug-raw"></span><br />
            <strong style="color:var(--gray-300);">Token:</strong> <span id="scan-debug-token"></span>
        </div>

        <div id="scan-error" style="display:none;margin-top:10px;" class="alert alert-danger">
            ❌ <span id="scan-error-text">Camera unavailable. Please use manual entry.</span>
        </div>

        <div style="margin-top:12px;display:flex;gap:10px;">
            <button id="startCameraBtn" onclick="startCamera()" type="button" class="btn-efn btn-primary" style="flex:1;">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Start Camera
            </button>
            <button id="stopCameraBtn" onclick="stopCamera()" type="button" class="btn-efn btn-outline" style="display:none;flex:1;">
                Stop Camera
            </button>
        </div>
    </div>

    @* ── Manual Entry Form ── *@
    <div class="efn-card">
        <div class="efn-card-header">
            <h3 style="font-size:15px;color:var(--white);display:flex;align-items:center;gap:8px;">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--blue-glow)" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Manual Entry
            </h3>
            <p style="font-size:13px;color:var(--gray-400);margin-top:4px;">Enter plate number if camera is unavailable.</p>
        </div>

        <form id="verifyForm" asp-controller="Gate" asp-action="Verify" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="qrToken" id="hiddenQrToken" value="" />

            <div class="form-group" style="margin-bottom:16px;">
                <label class="form-label">Plate Number</label>
                <input type="text" name="plateNumber" id="plateInput"
                       class="form-control"
                       placeholder="e.g. ABC 1234"
                       style="text-transform:uppercase;font-size:18px;font-weight:600;font-family:'Syne',sans-serif;letter-spacing:2px;"
                       autocomplete="off" autofocus />
            </div>

            <button type="submit" class="btn-efn btn-primary" style="width:100%;padding:13px;font-size:15px;">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Verify & Log
            </button>
        </form>
    </div>

    <div style="margin-top:20px;text-align:center;">
        <a asp-action="Log" style="font-size:13px;color:var(--gray-400);text-decoration:none;">
            📋 View Entry/Exit Log →
        </a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
    <script>
        let videoStream = null;
        let scanLoop    = null;
        let scanning    = false;

        const video       = document.getElementById('qr-video');
        const canvas      = document.getElementById('qr-canvas');
        const ctx         = canvas.getContext('2d');
        const placeholder = document.getElementById('qr-placeholder');
        const overlay     = document.getElementById('scan-overlay');

        async function startCamera() {
            document.getElementById('scan-error').style.display  = 'none';
            document.getElementById('scan-status').style.display = 'none';
            document.getElementById('scan-debug').style.display  = 'none';

            try {
                videoStream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } }
                });

                video.srcObject = videoStream;
                video.style.display = 'block';
                placeholder.style.display = 'none';
                overlay.style.display = 'block';

                document.getElementById('startCameraBtn').style.display = 'none';
                document.getElementById('stopCameraBtn').style.display  = 'flex';

                await video.play();
                scanning = true;
                scanLoop = requestAnimationFrame(tick);

            } catch (err) {
                document.getElementById('scan-error').style.display = 'block';
                document.getElementById('scan-error-text').textContent =
                    'Camera error: ' + err.message + '. Use manual entry.';
            }
        }

        function tick() {
            if (!scanning) return;

            if (video.readyState === video.HAVE_ENOUGH_DATA) {
                canvas.width  = video.videoWidth;
                canvas.height = video.videoHeight;

                // ✅ Mirror the canvas draw to match the flipped video display
                // Without this jsQR reads mirrored pixels and can't decode the QR
                ctx.save();
                ctx.scale(-1, 1);
                ctx.drawImage(video, -canvas.width, 0, canvas.width, canvas.height);
                ctx.restore();

                const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const code = jsQR(imageData.data, imageData.width, imageData.height, {
                    inversionAttempts: 'dontInvert'
                });

                if (code) {
                    scanning = false;
                    stopCamera();
                    onQRDetected(code.data);
                    return;
                }
            }

            scanLoop = requestAnimationFrame(tick);
        }

        function onQRDetected(rawText) {
            document.getElementById('scan-status').style.display = 'block';

            // The QR encodes: http://host/Permit/Verify?token=abc123
            // Url.Action() in ASP.NET Core generates query string params not route segments
            // So we read ?token= from the URL
            var token = rawText.trim();

            try {
                var urlObj = new URL(rawText);

                // ✅ Try query string first: /Permit/Verify?token=abc123
                var qParam = urlObj.searchParams.get('token');
                if (qParam && qParam.length >= 16) {
                    token = qParam.trim();
                } else {
                    // Fallback: try last path segment: /Permit/Verify/abc123
                    var segments = urlObj.pathname.split('/').filter(Boolean);
                    var lastSeg  = segments[segments.length - 1];
                    if (lastSeg && lastSeg.length >= 16) {
                        token = lastSeg.trim();
                    }
                }
            } catch (e) {
                // Not a valid URL — use rawText as-is
                token = rawText.trim();
            }

            // Debug info — shows exactly what was scanned and what token was extracted
            document.getElementById('scan-debug').style.display     = 'block';
            document.getElementById('scan-debug-raw').textContent   = rawText;
            document.getElementById('scan-debug-token').textContent = token;

            document.getElementById('hiddenQrToken').value = token;
            document.getElementById('plateInput').value    = '';

            setTimeout(function () {
                document.getElementById('verifyForm').submit();
            }, 800);
        }

        function stopCamera() {
            scanning = false;
            if (scanLoop) {
                cancelAnimationFrame(scanLoop);
                scanLoop = null;
            }
            if (videoStream) {
                videoStream.getTracks().forEach(t => t.stop());
                videoStream = null;
            }
            video.style.display       = 'none';
            overlay.style.display     = 'none';
            placeholder.style.display = 'block';
            document.getElementById('startCameraBtn').style.display = 'flex';
            document.getElementById('stopCameraBtn').style.display  = 'none';
        }

        document.getElementById('plateInput').addEventListener('input', function () {
            this.value = this.value.toUpperCase();
        });
    </script>
}
